pipeline {
    agent { label 'jenkins-slave2' }
 stages {
        stage('checkout') {
            steps {
               sh 'rm -rf hello-world-war'
                sh 'git clone https://github.com/Sudha2804/hello-world-war'
            }
        }
     stage('build') {
           steps {
              sh 'cd hello-world-war'
              sh 'mvn clean package'
    
         }
     }
 stage('deploy') {
           steps {
           echo '"deploying hello-world-war application"'
    sh 'scp /opt/jenkins/workspace/newjob/target/hello-world-war-1.0.0.war . ubuntu@43.204.218.0:home/ubuntu/apache-tomcat-10.1.34/webapps'
        sh 'cd /home/ubuntu/apache-tomcat-10.1.34/bin'
            sh './shutdown.sh'
            sh './startup.sh'
   }
}

        }
}

pipeline {
    agent { label 'jenkins-slave2' }
 stages {
        stage('checkout') {
            steps {
               sh 'rm -rf hello-world-war'
                sh 'git clone https://github.com/Sudha2804/hello-world-war'
            }
        }
     stage('build') {
           steps {
              sh 'cd hello-world-war'
              sh 'mvn clean package'
    
         }
     }
 stage('deploy') {
           steps {
              sh 'cd /var/lib/jenkins/workspace/newjob/apache-tomcat-10.1.34/webapps/'
              sh 'cp /home/ubuntu/hello-world-war/target/hello-world-war-1.0.0.war .'
               sh 'cd bin/'
            sh './shutdown'
            sh './startup'
   }
}
}
}

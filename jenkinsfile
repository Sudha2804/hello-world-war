pipeline {
 parameters {
        string(name: 'cmd', package: 'Mr Jenkins', description: 'Who should I say hello to?')
        choice(name: 'ch', choices: ['One', 'Two', 'Three'], description: 'Pick something')

     }
    agent any 
    stages {
        stage('checkout') {
            steps {
                sh 'git clone https://github.com/Sudha2804/hello-world-war'
            }
        }
stage('build') {
            steps {
sh 'cd hello-world-war'
sh 'mvn clean package'
    
}
}
    }
}


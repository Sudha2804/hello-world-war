pipeline {
    agent { label 'jenkins-slave2' }
 stages {
        stage('checkout') {
            steps {
               sh 'rm -rf hello-world-war'
                sh 'git clone https://github.com/Sudha2804/hello-world-war'
            }
        }
     stage('build') {
           steps {
              sh 'cd hello-world-war'
              sh 'mvn clean package'
    
         }
     }
 stage('deploy') {
           steps {
           echo '"deploying hello-world-war application"'
    sh 'cd /home/ubuntu/apache-tomcat-10.1.34/webapps'
              sh 'cp /opt/jenkins/workspace/newjob/hello-world-war/target/hello-world-war-1.0.0.war .'
               sh 'cd /home/ubuntu/apache-tomcat-10.1.34/bin'
            sh './shutdown'
            sh './startup'
   }
}
  stage ('post') {
        always {
            sh 'echo "Cleaning up..."'
        }
        
        success {
           sh mail to: 'sudha.gc28@gmail.com'
                sh 'subject: Pipeline Succeeded'
                sh 'body: Your Jenkins Pipeline has completed successfully.'
        }
        


}
}
}
